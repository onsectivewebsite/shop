# ============================================================================
# Onsective — environment variables
# Copy this file to .env (root) for local dev.
# Production values live in AWS Secrets Manager — never commit .env.
# ============================================================================

# ---- Core ------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3001

# ---- Database --------------------------------------------------------------
# Local: docker-compose postgres or `pnpm db:up` (TBD)
DATABASE_URL=postgresql://onsective:onsective@localhost:5432/onsective?schema=public

# ---- Redis (BullMQ queue, rate-limit token buckets) -----------------------
REDIS_URL=redis://localhost:6379

# ---- OpenSearch (Phase 4 — relevance/synonyms/facets) ---------------------
# Leave empty in dev to fall back to Postgres FTS on Product.searchVector.
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=onsective-products

# ---- Auth / sessions -------------------------------------------------------
SESSION_SECRET=change-me-32-bytes-minimum-please

# ---- Console (admin/PM app) ------------------------------------------------
# Comma-separated IPs allowed to access apps/console.
# Empty = no restriction (dev only). In prod, set to office VPN IPs.
CONSOLE_IP_ALLOWLIST=

# ---- Stripe (Phase 1) ------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- AWS (S3 for product images) -------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_PRODUCTS=onsective-products-dev
S3_BUCKET_KYC=onsective-kyc-dev
# CDN base for serving product images. Leave empty in dev to fall back to
# https://{bucket}.s3.{region}.amazonaws.com/{key}. In prod, point this at
# your CloudFront distribution (e.g. https://images.itsnottechy.cloud).
S3_PUBLIC_URL_BASE=

# ---- Email (SES) -----------------------------------------------------------
EMAIL_FROM=no-reply@onsective.local
EMAIL_REPLY_TO=help@onsective.local

# ---- SMS (Twilio + MSG91) --------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=

# ---- Shipping (Phase 3) ----------------------------------------------------
EASYPOST_API_KEY=
EASYPOST_WEBHOOK_SECRET=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ---- Observability ---------------------------------------------------------
# Set DSN to enable Sentry (instrumentation.ts hooks it lazily — empty = noop).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Feature flags / rollout ----------------------------------------------
ENABLE_DARK_MODE=true
ENABLE_PASSKEYS=false

# ---- WebAuthn / passkeys --------------------------------------------------
# RP ID is the eTLD+1 of the site (no scheme, no port). Must match the origin.
# In dev: "localhost". In prod: "itsnottechy.cloud".
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Onsective
# Origin (with scheme + port) the browser will call from. Comma-separate to
# allow multiple in dev (apps/web + ngrok tunnels for testing on phones).
WEBAUTHN_ORIGIN=http://localhost:3000

# ---- i18n ------------------------------------------------------------------
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,hi

# ---- E2E ------------------------------------------------------------------
E2E_BASE_URL=http://localhost:3000
E2E_CONSOLE_URL=http://localhost:3001
